<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Estratégia de Conteúdo — MultiClean 360</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --navy:#0B3D91;
    --navy-deep:#072a66;
    --azure:#1E88C7;
    --cyan:#3FC1C9;
    --gold:#C9A84C;
    --gold-light:#e8cd7e;
    --ink:#0f1b2d;
    --slate:#5a6b85;
    --mist:#8a99b3;
    --paper:#ffffff;
    --paper-2:#f4f8fd;
    --paper-3:#eaf2fb;
    --line:#dde7f3;
    --ok:#2e8b57;
    --ok-bg:#e3f4ea;
    --warn:#b8860b;
    --warn-bg:#fbf2da;
    --no:#c0392b;
    --no-bg:#fbeae8;
  }
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{
    font-family:'Inter',sans-serif;
    background:#dce6f2;
    color:var(--ink);
    line-height:1.65;
    -webkit-font-smoothing:antialiased;
    padding:0;
  }
  .doc{max-width:920px;margin:0 auto;background:var(--paper);box-shadow:0 20px 80px rgba(7,42,102,.18)}

  /* ===== PROGRESS BAR ===== */
  .progress{position:fixed;top:0;left:0;height:4px;background:linear-gradient(90deg,var(--cyan),var(--gold));width:0%;z-index:200;transition:width .1s linear}

  /* ===== HERO ===== */
  .hero{
    position:relative;
    background:linear-gradient(160deg,#072a66 0%,#0B3D91 45%,#1257ad 100%);
    padding:80px 48px 120px;
    text-align:center;
    overflow:hidden;
    isolation:isolate;
  }
  .bubble{position:absolute;border-radius:50%;background:radial-gradient(circle at 30% 30%,rgba(255,255,255,.18),rgba(63,193,201,.05));border:1px solid rgba(255,255,255,.08);z-index:-1;animation:float linear infinite}
  .bubble:nth-child(1){width:120px;height:120px;left:6%;top:18%;animation-duration:14s}
  .bubble:nth-child(2){width:70px;height:70px;right:10%;top:12%;animation-duration:11s;animation-delay:-3s}
  .bubble:nth-child(3){width:200px;height:200px;right:-40px;bottom:-30px;animation-duration:18s;animation-delay:-6s}
  .bubble:nth-child(4){width:48px;height:48px;left:16%;bottom:22%;animation-duration:9s;animation-delay:-2s}
  .bubble:nth-child(5){width:30px;height:30px;left:46%;top:14%;animation-duration:12s;animation-delay:-5s}
  @keyframes float{0%{transform:translateY(0) translateX(0)}25%{transform:translateY(-18px) translateX(10px)}50%{transform:translateY(-6px) translateX(-12px)}75%{transform:translateY(-22px) translateX(6px)}100%{transform:translateY(0) translateX(0)}}

  .hero-logo{display:inline-flex;background:#fff;padding:16px 26px;border-radius:18px;margin-bottom:26px;box-shadow:0 12px 40px rgba(0,0,0,.25)}
  .hero-logo img{height:64px;display:block}
  .foot-logo{height:60px;margin:0 auto 18px;display:block}
  .hero-badge{
    display:inline-flex;align-items:center;gap:8px;
    background:rgba(201,168,76,.14);
    border:1px solid rgba(201,168,76,.45);
    color:var(--gold-light);
    font-family:'Space Grotesk',sans-serif;font-size:11px;font-weight:600;
    letter-spacing:3px;text-transform:uppercase;
    padding:8px 20px;border-radius:30px;margin-bottom:28px;
    backdrop-filter:blur(4px);
  }
  .hero-badge .drop{width:7px;height:9px;background:var(--cyan);border-radius:0 50% 50% 50%;transform:rotate(45deg);display:inline-block}

  .hero h1{
    font-family:'Space Grotesk',sans-serif;
    font-size:clamp(38px,6vw,62px);
    font-weight:700;color:#fff;line-height:1.04;letter-spacing:-1.5px;
  }
  .hero h1 .clean{
    background:linear-gradient(120deg,var(--cyan),#7fe5d8);
    -webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;
  }
  .hero h1 .num{color:var(--gold-light)}
  .hero .tagline{
    color:#bcd6f2;font-size:clamp(15px,2.2vw,18px);font-weight:500;
    margin-top:18px;max-width:560px;margin-left:auto;margin-right:auto;
  }
  .hero-meta{margin-top:34px;display:flex;gap:14px;flex-wrap:wrap;justify-content:center}
  .hero-meta .chip{
    background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);
    color:#d4e4f7;font-size:12.5px;font-weight:500;
    padding:8px 16px;border-radius:30px;backdrop-filter:blur(4px);
    display:flex;align-items:center;gap:7px;
  }
  .hero-meta .chip svg{width:14px;height:14px;stroke:var(--gold-light);fill:none;stroke-width:2}

  .wave{position:absolute;bottom:-1px;left:0;width:100%;line-height:0;z-index:1}
  .wave svg{width:100%;height:70px;display:block}

  /* ===== NAV ===== */
  .nav{
    position:sticky;top:0;z-index:100;
    background:rgba(255,255,255,.92);backdrop-filter:blur(12px);
    border-bottom:1px solid var(--line);
    display:flex;justify-content:center;gap:4px;padding:12px;
    flex-wrap:wrap;
  }
  .nav a{
    font-family:'Space Grotesk',sans-serif;font-size:12.5px;font-weight:600;
    color:var(--slate);text-decoration:none;padding:8px 16px;border-radius:30px;
    transition:all .2s;letter-spacing:.3px;
  }
  .nav a:hover{color:var(--navy);background:var(--paper-3)}
  .nav a.active{color:#fff;background:var(--navy)}

  /* ===== SECTION ===== */
  .section{padding:64px 48px;border-bottom:1px solid var(--line);position:relative}
  .section:last-of-type{border-bottom:none}
  .eyebrow{
    font-family:'Space Grotesk',sans-serif;font-size:12px;font-weight:600;
    letter-spacing:3px;text-transform:uppercase;color:var(--azure);
    display:flex;align-items:center;gap:12px;margin-bottom:10px;
  }
  .eyebrow::before{content:'';width:28px;height:2px;background:var(--gold);border-radius:2px}
  .section h2{
    font-family:'Space Grotesk',sans-serif;font-size:clamp(26px,4vw,36px);
    font-weight:700;color:var(--ink);letter-spacing:-.8px;line-height:1.1;margin-bottom:12px;
  }
  .section .lead{font-size:15.5px;color:var(--slate);max-width:680px;margin-bottom:36px}

  .reveal{opacity:0;transform:translateY(28px);transition:opacity .7s cubic-bezier(.16,1,.3,1),transform .7s cubic-bezier(.16,1,.3,1)}
  .reveal.in{opacity:1;transform:none}

  /* ===== SNAPSHOT ===== */
  .snapshot{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:8px}
  .stat{
    background:linear-gradient(160deg,var(--paper-2),#fff);
    border:1px solid var(--line);border-radius:16px;padding:22px 18px;text-align:center;
    position:relative;overflow:hidden;
  }
  .stat::before{content:'';position:absolute;top:0;left:0;width:100%;height:3px;background:linear-gradient(90deg,var(--azure),var(--cyan))}
  .stat .ico{width:38px;height:38px;margin:0 auto 10px;display:flex;align-items:center;justify-content:center;background:var(--paper-3);border-radius:11px}
  .stat .ico svg{width:20px;height:20px;stroke:var(--navy);fill:none;stroke-width:2}
  .stat .num{font-family:'Space Grotesk',sans-serif;font-size:26px;font-weight:700;color:var(--navy);line-height:1}
  .stat .lbl{font-size:11.5px;color:var(--mist);font-weight:500;margin-top:6px;letter-spacing:.2px}

  /* ===== PERSONA ===== */
  .persona-tabs{display:flex;gap:10px;margin-bottom:24px;flex-wrap:wrap}
  .ptab{
    flex:1;min-width:200px;cursor:pointer;
    background:var(--paper-2);border:1.5px solid var(--line);border-radius:14px;
    padding:16px 18px;display:flex;align-items:center;gap:14px;transition:all .25s;
  }
  .ptab:hover{border-color:var(--azure)}
  .ptab.active{background:linear-gradient(135deg,var(--navy),#1257ad);border-color:var(--navy)}
  .ptab.active .pt-name,.ptab.active .pt-role{color:#fff}
  .ptab.active .pt-avatar{background:rgba(255,255,255,.15)}
  .ptab.active .pt-avatar svg{stroke:#fff}
  .pt-avatar{width:46px;height:46px;border-radius:50%;background:var(--paper-3);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .25s}
  .pt-avatar svg{width:24px;height:24px;stroke:var(--navy);fill:none;stroke-width:1.8;transition:all .25s}
  .pt-name{font-family:'Space Grotesk',sans-serif;font-size:16px;font-weight:700;color:var(--ink);transition:color .25s}
  .pt-role{font-size:12px;color:var(--slate);transition:color .25s}

  .persona-panel{display:none;animation:fadeUp .5s ease}
  .persona-panel.active{display:block}
  @keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}

  .pcard{border:1px solid var(--line);border-radius:18px;overflow:hidden}
  .pcard-head{background:linear-gradient(135deg,var(--navy),#1257ad);padding:26px 28px;color:#fff;display:flex;align-items:center;gap:18px}
  .pcard-head .big-avatar{width:64px;height:64px;border-radius:50%;background:rgba(255,255,255,.14);display:flex;align-items:center;justify-content:center;flex-shrink:0;border:2px solid rgba(255,255,255,.25)}
  .pcard-head .big-avatar svg{width:34px;height:34px;stroke:#fff;fill:none;stroke-width:1.8}
  .pcard-head h3{font-family:'Space Grotesk',sans-serif;font-size:22px;font-weight:700}
  .pcard-head .meta{font-size:13px;color:#bcd6f2;margin-top:2px}
  .pcard-body{display:grid;grid-template-columns:1fr 1fr;gap:0}
  .pblock{padding:22px 26px;border-right:1px solid var(--line);border-bottom:1px solid var(--line)}
  .pblock:nth-child(even){border-right:none}
  .pblock h4{font-family:'Space Grotesk',sans-serif;font-size:12px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--azure);margin-bottom:12px;display:flex;align-items:center;gap:8px}
  .pblock h4 svg{width:16px;height:16px;stroke:var(--azure);fill:none;stroke-width:2}
  .pblock p{font-size:13.5px;color:var(--slate)}
  .pblock ul{list-style:none}
  .pblock li{font-size:13.5px;color:var(--slate);padding:5px 0 5px 24px;position:relative}
  .pblock li::before{content:'';position:absolute;left:2px;top:11px;width:7px;height:7px;border-radius:50%;background:var(--cyan)}
  .quote{padding:22px 26px;background:var(--paper-2);font-style:italic;font-size:15px;color:var(--navy);position:relative}
  .quote::before{content:'\201C';font-family:Georgia,serif;font-size:54px;color:var(--gold);position:absolute;left:18px;top:6px;line-height:1;opacity:.5}
  .quote span{display:block;padding-left:32px}

  /* ===== TONE ===== */
  .tone-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:8px}
  .tone-card{border-radius:16px;padding:24px;border:1.5px solid}
  .tone-card.do{background:var(--ok-bg);border-color:#a9ddbf}
  .tone-card.dont{background:var(--no-bg);border-color:#f0bcb4}
  .tone-card h4{font-family:'Space Grotesk',sans-serif;font-size:15px;font-weight:700;margin-bottom:14px;display:flex;align-items:center;gap:10px}
  .tone-card.do h4{color:#1d6b3f}
  .tone-card.dont h4{color:#a02d20}
  .tone-card h4 .badge-ico{width:26px;height:26px;border-radius:8px;display:flex;align-items:center;justify-content:center}
  .tone-card.do .badge-ico{background:#1d6b3f}
  .tone-card.dont .badge-ico{background:#a02d20}
  .tone-card .badge-ico svg{width:15px;height:15px;stroke:#fff;fill:none;stroke-width:2.5}
  .tone-card ul{list-style:none}
  .tone-card li{font-size:13.5px;padding:6px 0 6px 24px;position:relative;color:#384a5e}
  .tone-card.do li::before{content:'';position:absolute;left:4px;top:13px;width:8px;height:5px;border-left:2px solid #1d6b3f;border-bottom:2px solid #1d6b3f;transform:rotate(-45deg)}
  .tone-card.dont li::before{content:'\00D7';position:absolute;left:3px;top:5px;color:#a02d20;font-weight:700;font-size:16px}
  .voice-strip{margin-top:0;margin-bottom:20px;background:linear-gradient(120deg,var(--navy),#1257ad);border-radius:14px;padding:20px 26px;color:#fff;display:flex;align-items:center;gap:16px}
  .voice-strip .vs-ico{width:42px;height:42px;border-radius:11px;background:rgba(255,255,255,.14);display:flex;align-items:center;justify-content:center;flex-shrink:0}
  .voice-strip .vs-ico svg{width:22px;height:22px;stroke:var(--gold-light);fill:none;stroke-width:2}
  .voice-strip p{font-size:14px;color:#d4e4f7}
  .voice-strip strong{color:#fff;font-family:'Space Grotesk',sans-serif}

  /* ===== PILLARS ===== */
  .pillars{display:flex;flex-direction:column;gap:14px}
  .pillar{
    border:1px solid var(--line);border-radius:16px;overflow:hidden;
    transition:box-shadow .3s,transform .3s;background:#fff;
  }
  .pillar:hover{box-shadow:0 10px 30px rgba(11,61,145,.1);transform:translateX(4px)}
  .pillar-head{display:flex;align-items:center;gap:18px;padding:20px 24px;cursor:pointer}
  .pillar-ico{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative;color:#3FC1C9}
  .pillar-ico svg{width:26px;height:26px;stroke:#fff;fill:none;stroke-width:2;z-index:1}
  .pillar:nth-child(1) .pillar-ico{background:linear-gradient(135deg,#1E88C7,#3FC1C9)}
  .pillar:nth-child(2) .pillar-ico{background:linear-gradient(135deg,#0B3D91,#1E88C7)}
  .pillar:nth-child(3) .pillar-ico{background:linear-gradient(135deg,#2e8b57,#3FC1C9)}
  .pillar:nth-child(4) .pillar-ico{background:linear-gradient(135deg,#C9A84C,#e8cd7e)}
  .pillar:nth-child(5) .pillar-ico{background:linear-gradient(135deg,#072a66,#0B3D91)}
  .pillar-ico .pulse{position:absolute;inset:0;border-radius:14px;border:2px solid rgba(255,255,255,.6);opacity:0;animation:pulse 2.5s ease-out infinite}
  @keyframes pulse{0%{transform:scale(1);opacity:.5}100%{transform:scale(1.3);opacity:0}}
  .pillar-title{flex:1}
  .pillar-title h3{font-family:'Space Grotesk',sans-serif;font-size:17px;font-weight:700;color:var(--ink)}
  .pillar-title p{font-size:13px;color:var(--slate);margin-top:2px}
  .pillar-pct{display:flex;flex-direction:column;align-items:center;gap:6px;min-width:64px}
  .ring{position:relative;width:54px;height:54px}
  .ring svg{transform:rotate(-90deg)}
  .ring .pct-num{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:'Space Grotesk',sans-serif;font-size:14px;font-weight:700;color:var(--navy)}
  .pillar-body{max-height:0;overflow:hidden;transition:max-height .4s ease;background:var(--paper-2)}
  .pillar.open .pillar-body{max-height:340px}
  .pillar-body-inner{padding:20px 24px 24px;border-top:1px solid var(--line)}
  .pillar-body-inner .examples-label{font-size:11px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--mist);margin-bottom:10px}
  .ex-chips{display:flex;flex-wrap:wrap;gap:8px}
  .ex-chip{background:#fff;border:1px solid var(--line);border-radius:30px;padding:7px 14px;font-size:12.5px;color:var(--navy);font-weight:500}

  /* ===== CALENDAR ===== */
  .cal-legend{display:flex;flex-wrap:wrap;gap:14px;margin-bottom:24px}
  .cal-legend .lg{display:flex;align-items:center;gap:7px;font-size:12.5px;color:var(--slate);font-weight:500}
  .cal-legend .dot{width:11px;height:11px;border-radius:3px}
  .d-edu{background:#1E88C7}.d-auth{background:#0B3D91}.d-prova{background:#2e8b57}.d-bast{background:#C9A84C}.d-vend{background:#c0392b}

  .weeks{display:flex;flex-direction:column;gap:28px}
  .week h3{font-family:'Space Grotesk',sans-serif;font-size:14px;font-weight:700;color:var(--navy);margin-bottom:14px;display:flex;align-items:center;gap:10px}
  .week h3::before{content:'';width:8px;height:8px;border-radius:0 50% 50% 50%;background:var(--cyan);transform:rotate(45deg)}
  .week h3 .wk-tag{margin-left:auto;font-family:'Inter',sans-serif;font-size:11px;font-weight:500;color:var(--mist);letter-spacing:.5px}
  .post-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
  .post{
    border:1px solid var(--line);border-radius:14px;padding:16px;background:#fff;
    transition:box-shadow .25s,transform .25s;position:relative;overflow:hidden;
  }
  .post::before{content:'';position:absolute;top:0;left:0;width:4px;height:100%}
  .post.edu::before{background:#1E88C7}.post.auth::before{background:#0B3D91}.post.prova::before{background:#2e8b57}.post.bast::before{background:#C9A84C}.post.vend::before{background:#c0392b}
  .post:hover{box-shadow:0 8px 22px rgba(11,61,145,.12);transform:translateY(-3px)}
  .post-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
  .post-day{font-family:'Space Grotesk',sans-serif;font-size:12px;font-weight:700;color:var(--navy)}
  .post-fmt{font-size:10px;font-weight:600;letter-spacing:.5px;text-transform:uppercase;background:var(--paper-3);color:var(--slate);padding:3px 9px;border-radius:20px}
  .post-tag{display:inline-block;font-size:10px;font-weight:700;padding:2px 9px;border-radius:20px;margin-bottom:8px;font-family:'Space Grotesk',sans-serif}
  .tag-edu{background:#e1f0fb;color:#1565a0}.tag-auth{background:#e0e8f7;color:#0B3D91}.tag-prova{background:#e3f4ea;color:#1d6b3f}.tag-bast{background:#fbf2da;color:#8a6d1a}.tag-vend{background:#fbeae8;color:#a02d20}
  .post p{font-size:13px;color:var(--ink);font-weight:500;line-height:1.45}
  .post .cta-note{font-size:11.5px;color:var(--slate);margin-top:8px;display:flex;align-items:flex-start;gap:5px}
  .post .cta-note svg{width:13px;height:13px;stroke:var(--azure);fill:none;stroke-width:2;flex-shrink:0;margin-top:2px}

  .rhythm{margin-top:34px;background:var(--paper-2);border:1px solid var(--line);border-radius:16px;padding:24px}
  .rhythm h4{font-family:'Space Grotesk',sans-serif;font-size:14px;font-weight:700;color:var(--navy);margin-bottom:16px}
  .bar-row{display:flex;align-items:center;gap:14px;margin-bottom:12px}
  .bar-row:last-child{margin-bottom:0}
  .bar-label{font-size:12.5px;font-weight:600;color:var(--slate);width:96px;flex-shrink:0;display:flex;align-items:center;gap:7px}
  .bar-label .dot{width:9px;height:9px;border-radius:2px}
  .bar-track{flex:1;height:24px;background:#fff;border-radius:8px;overflow:hidden;border:1px solid var(--line)}
  .bar-fill{height:100%;border-radius:8px;width:0;transition:width 1.2s cubic-bezier(.16,1,.3,1);display:flex;align-items:center;justify-content:flex-end;padding-right:8px}
  .bar-fill span{font-size:11px;font-weight:700;color:#fff;font-family:'Space Grotesk',sans-serif}

  /* ===== TAKEAWAYS ===== */
  .takeaways{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
  .take{background:linear-gradient(160deg,var(--paper-2),#fff);border:1px solid var(--line);border-radius:16px;padding:22px;position:relative}
  .take .t-ico{width:40px;height:40px;border-radius:11px;background:var(--navy);display:flex;align-items:center;justify-content:center;margin-bottom:14px}
  .take .t-ico svg{width:21px;height:21px;stroke:var(--gold-light);fill:none;stroke-width:2}
  .take h4{font-family:'Space Grotesk',sans-serif;font-size:14.5px;font-weight:700;color:var(--ink);margin-bottom:7px}
  .take p{font-size:13px;color:var(--slate)}

  .ref-box{margin-top:24px;border:1px dashed var(--gold);background:var(--warn-bg);border-radius:14px;padding:18px 22px;display:flex;align-items:flex-start;gap:14px}
  .ref-box .r-ico{width:38px;height:38px;border-radius:10px;background:var(--gold);display:flex;align-items:center;justify-content:center;flex-shrink:0}
  .ref-box .r-ico svg{width:20px;height:20px;stroke:#fff;fill:none;stroke-width:2}
  .ref-box p{font-size:13px;color:#7a5e15}
  .ref-box strong{color:#5c4709}

  /* ===== FOOTER ===== */
  .foot{background:linear-gradient(160deg,#072a66,#0B3D91);padding:40px 48px;text-align:center;position:relative;overflow:hidden}
  .foot .drop-logo{width:46px;height:58px;margin:0 auto 16px;background:linear-gradient(160deg,var(--cyan),var(--azure));border-radius:0 50% 50% 50%;transform:rotate(45deg);display:flex;align-items:center;justify-content:center;box-shadow:0 8px 24px rgba(63,193,201,.4)}
  .foot .drop-logo span{transform:rotate(-45deg);font-family:'Space Grotesk',sans-serif;font-weight:700;color:#fff;font-size:18px}
